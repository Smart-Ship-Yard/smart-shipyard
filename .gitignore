# 파이썬 캐시 파일 무시 (프로그램 속도 향상용 파일들)
__pycache__/
*.pyc
*.pyo
# 가상환경 폴더 무시 (용량이 너무 크고 컴퓨터마다 환경이 다르니까!)
venv/
.venv/
# 비밀번호가 담긴 금고 파일 무시
.env
# VS Code 설정 파일들 (개인 환경 설정이라 굳이 공유 안 함)
.vscode/
# colcon (ROS 2) 빌드 산출물
build/
install/
log/
# Node.js 의존성 폴더 (npm install로 각자 재생성)
node_modules/
# Orbbec SDK 런타임 로그 (실행 위치에 자동 생성됨)
Log/
OrbbecSDK.log*
edge/ros2_ws/src/ship_ugv_perception/weights/*.pt
# 프론트엔드(Vite) 빌드 산출물 — npm run build가 만드는 배포용 파일
dist/
dist-ssr/
*.local
# 각종 로그 파일 (npm/yarn 등이 에러 시 자동 생성)
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
# 에디터·개인 도구 설정 (개인 환경이라 공유 안 함)
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# Claude Code 등 AI 도구의 개인 로컬 설정
.claude/
